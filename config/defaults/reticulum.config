# Default Reticulum configuration.
#
# Three interfaces are enabled by default:
#
#   * AutoInterface  — multicast peer discovery on every link-local
#                      segment the host has, including ygg0 once
#                      Yggdrasil is up. Costs nothing on a quiet net.
#
#   * TCPServerInterface — accepts incoming RNS peers on every IPv6
#                          address the host has, including the
#                          Yggdrasil-derived 200::/7 address. Other
#                          Resilum / Reticulum nodes can dial us by
#                          our Yggdrasil IPv6 + port 4242.
#
#   * TCPClientInterface to rmap.world — bootstrap connectivity into                                                                
#                          the global Reticulum mesh on first boot.                                                                 
#                          Without it a fresh node would not see                                                                    
#                          anyone until at least one inbound peer                                                                   
#                          arrives, which can take a while in a young                                                                    
#                          network.
#
# Operators on a fully-isolated network can disable any of these in
# /config/reticulum/config; this file is just the seed.

[reticulum]
  enable_transport = Yes
  share_instance = Yes
  instance_name = resilum

[logging]
  loglevel = 4

[interfaces]
  [[LAN AutoDiscovery]]
    type = AutoInterface
    enabled = Yes

  [[Yggdrasil TCP listener]]
    type = TCPServerInterface
    enabled = Yes
    listen_ip = ::
    listen_port = 4242

  [[Backbone — rmap.world]]
    type = TCPClientInterface
    enabled = Yes
    target_host = rmap.world
    target_port = 4242
