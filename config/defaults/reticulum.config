# Default Reticulum configuration.
#
# Two layers of connectivity:
#
# 1. Static bootstraps (8 of them) — TCPClient interfaces to a
#    geographically diverse set of public RNS hubs from
#    https://directory.rns.recipes:
#
#      * 5 over clearnet (DE, HU, US-East, US-Central, AU). All
#        flagged `bootstrap_only = yes` — used only to seed initial
#        connectivity, then dropped once the discovery layer has
#        found `autoconnect_discovered_interfaces` live peers.
#      * 3 over the Yggdrasil 200::/7 overlay (Beleth, Kemerovo RU,
#        Spaceman). Kept as permanent anchors *without*
#        `bootstrap_only`. Yggdrasil itself is resilient to clearnet
#        censorship — it routes through whatever peers are still
#        reachable — so these stay connected as the no-clearnet
#        fallback. The cost is keeping three TCP connections open;
#        the win is that we never go fully isolated when our
#        country's clearnet RNS hubs are blocked.
#
# 2. Interface discovery — Reticulum's signed, deduplicated
#    peer-lookup protocol. Once two Resilum nodes share any common
#    transport hop (a bootstrap, the LAN, ygg0, …) they exchange
#    discovery announces, build direct links, and prefer those over
#    the static bootstraps. Configured via:
#
#      * discover_interfaces = yes               (in [reticulum])
#      * network_identity = .../identities/resilum
#      * autoconnect_discovered_interfaces = 5   (global cap)
#      * discoverable = yes  on our public listener
#      * mode = gateway      on the same listener (server-style)
#      * bootstrap_only = yes on each clearnet TCPClient
#
#    `network_identity` points to a 64-byte private key generated by
#    entrypoint.sh on first boot via `rnid -g`; it is reused across
#    container restarts so the node has a stable identity in the
#    discovery network.
#
# Operators on a fully-isolated network can disable everything via
# `enabled = no` per interface, or `discover_interfaces = no`.

[reticulum]
  enable_transport = yes
  share_instance = yes
  instance_name = resilum

  # Interface-discovery layer
  discover_interfaces = yes
  network_identity = /config/reticulum/storage/identities/resilum
  autoconnect_discovered_interfaces = 5

[logging]
  loglevel = 4

[interfaces]
  [[LAN AutoDiscovery]]
    type = AutoInterface
    enabled = yes

  # Public clearnet ingress. Set RESILUM_RNS_LISTEN (comma-separated
  # host:port, IPv6 in [brackets]) to bind explicit addresses; each entry
  # becomes its own listener block.
  # >>> resilum:managed rns-public-listen — rendered from RESILUM_RNS_LISTEN
  [[Public TCP listener]]
    type = TCPServerInterface
    enabled = yes
    listen_ip = ::
    listen_port = 4242
    discoverable = yes
    discovery_name = resilum
    mode = gateway
  # <<< resilum:managed

  [[Bootstrap — Reserve.Network DE]]
    type = TCPClientInterface
    enabled = yes
    target_host = istanbul.reserve.network
    target_port = 9034
    bootstrap_only = yes

  [[Bootstrap — RNS Budapest HU]]
    type = TCPClientInterface
    enabled = yes
    target_host = vjs.hu
    target_port = 5858
    bootstrap_only = yes

  [[Bootstrap — Beleth RNS Hub US]]
    type = TCPClientInterface
    enabled = yes
    target_host = rns.beleth.net
    target_port = 4242
    bootstrap_only = yes

  [[Bootstrap — g00n.cloud Dallas]]
    type = TCPClientInterface
    enabled = yes
    target_host = dfw.us.g00n.cloud
    target_port = 6969
    bootstrap_only = yes

  [[Bootstrap — Inertia.Chat AU]]
    type = TCPClientInterface
    enabled = yes
    target_host = use.inertia.chat
    target_port = 4242
    bootstrap_only = yes

  [[Anchor via Yggdrasil — Beleth]]
    type = TCPClientInterface
    enabled = yes
    target_host = 200:3953:999b:282e:e526:bcd2:c329:31a
    target_port = 4343

  [[Anchor via Yggdrasil — Kemerovo RU]]
    type = TCPClientInterface
    enabled = yes
    target_host = 203:f54a:ffa2:650d:df9d:1473:5228:94dc
    target_port = 43434

  [[Anchor via Yggdrasil — Spaceman]]
    type = TCPClientInterface
    enabled = yes
    target_host = 201:e73a:61ee:ca68:4bc5:99d5:fd70:ded1
    target_port = 4343
